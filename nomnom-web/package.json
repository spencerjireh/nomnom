{
  "name": "nomnom-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Browser sender / receiver / pair client for nomnom, speaking the relay protocol with full CLI crypto interop.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "gen:fixtures": "uv run python ../tools/gen_crypto_fixtures.py --out test/fixtures/crypto-vectors.json"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
